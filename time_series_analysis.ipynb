  {
   "cell_type": "markdown",
   "id": "e90ca8b6",
   "metadata": {},
   "source": [
    "### LINEAR REGRESSION TREND ANALYSIS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6ed4597d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "TREND ANALYSIS (Linear Regression)\n",
      "Slope: -0.000185°C/year\n",
      "Temperature change per decade: -0.002°C\n",
      "R-squared: 0.0000\n",
      "P-value: 9.7320e-01\n",
      "Trend is NOT statistically significant (p ≥ 0.05)\n"
     ]
    }
   ],
   "source": [
    "# Extract years and temperatures as arrays\n",
    "years = np.array(annual_temps.index)\n",
    "temps = annual_temps.values\n",
    "\n",
    "# Perform linear regression\n",
    "slope, intercept, r_value, p_value, std_err = stats.linregress(years, temps)\n",
    "\n",
    "# Calculate trend per decade (10 years)\n",
    "trend_per_decade = slope * 10\n",
    "\n",
    "print(\"TREND ANALYSIS (Linear Regression)\")\n",
    "print(f\"Slope: {slope:.6f}°C/year\")\n",
    "print(f\"Temperature change per decade: {trend_per_decade:.3f}°C\")\n",
    "print(f\"R-squared: {r_value**2:.4f}\")\n",
    "print(f\"P-value: {p_value:.4e}\")\n",
    "\n",
    "# Check statistical significance\n",
    "if p_value < 0.05:\n",
    "    print(f\"Trend is STATISTICALLY SIGNIFICANT (p < 0.05)\")\n",
    "else:\n",
    "    print(f\"Trend is NOT statistically significant (p ≥ 0.05)\")"
   ]
  },
  {
   "cell_type": "code",
